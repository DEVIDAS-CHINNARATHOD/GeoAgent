# GeoAgent Backend Environment Variables
# Copy this file to .env and fill in your values

# Groq LLM (required)
# Obtain from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Maps API - Foursquare Places API (optional, synthetic data used if absent)
# Obtain from https://developer.foursquare.com/
MAPS_API_KEY=your_foursquare_api_key_here
MAPS_API_URL=https://api.foursquare.com/v3/places/search

# Weather API - OpenWeatherMap (optional, synthetic data used if absent)
# Obtain from https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Application settings (optional)
DEBUG=false
